table dCalendario
	lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567890

	column Date
		dataType: dateTime
		isKey
		formatString: Short Date
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678901
		summarizeBy: none
		sourceColumn: Date

		annotation SummarizationSetBy = Automatic

	column Ano
		dataType: int64
		formatString: 0
		lineageTag: c3d4e5f6-a7b8-9012-cdef-123456789012
		summarizeBy: none
		sourceColumn: Ano

		annotation SummarizationSetBy = Automatic

	column 'Mes Numero'
		dataType: int64
		formatString: 0
		lineageTag: d4e5f6a7-b8c9-0123-def0-234567890123
		summarizeBy: none
		sourceColumn: Mes Numero

		annotation SummarizationSetBy = Automatic

	column 'Mes Nome'
		dataType: string
		lineageTag: e5f6a7b8-c9d0-1234-ef01-345678901234
		summarizeBy: none
		sourceColumn: Mes Nome

		annotation SummarizationSetBy = Automatic

	column 'Ano-Mes'
		dataType: string
		lineageTag: a7b8c9d0-e1f2-3456-0123-567890123456
		summarizeBy: none
		sortByColumn: Date
		sourceColumn: Ano-Mes

		annotation SummarizationSetBy = Automatic

	column Trimestre
		dataType: string
		lineageTag: b8c9d0e1-f2a3-4567-1234-678901234567
		summarizeBy: none
		sourceColumn: Trimestre

		annotation SummarizationSetBy = Automatic

	column 'Ano-Trimestre'
		dataType: string
		lineageTag: c9d0e1f2-a3b4-5678-2345-789012345678
		summarizeBy: none
		sortByColumn: Date
		sourceColumn: Ano-Trimestre

		annotation SummarizationSetBy = Automatic

	column Semestre
		dataType: string
		lineageTag: a3b4c5d6-e7f8-9012-6789-123456789012
		summarizeBy: none
		sourceColumn: Semestre

		annotation SummarizationSetBy = Automatic

	hierarchy 'Hierarquia de Datas'
		lineageTag: f1e2d3c4-b5a6-7890-1234-567890abcdef

		level Ano
			lineageTag: a1a2a3a4-b1b2-c1c2-d1d2-e1e2e3e4e5e6
			column: Ano

		level Trimestre
			lineageTag: b1b2b3b4-c1c2-d1d2-e1e2-f1f2f3f4f5f6
			column: Trimestre

		level 'Mes Nome'
			lineageTag: c1c2c3c4-d1d2-e1e2-f1f2-a1a2a3a4a5a6
			column: 'Mes Nome'

	partition dCalendario = calculated
		mode: import
		source =
				VAR _inicio = DATE(2020, 1, 1)
				VAR _fim    = DATE(2024, 12, 31)
				RETURN
				ADDCOLUMNS(
				    CALENDAR(_inicio, _fim),
				    "Ano",           YEAR([Date]),
				    "Mes Numero",    MONTH([Date]),
				    "Mes Nome",      FORMAT([Date], "MMM", "pt-BR"),
				    "Ano-Mes",       FORMAT([Date], "YYYY-MM"),
				    "Trimestre",     "T" & QUARTER([Date]),
				    "Ano-Trimestre", FORMAT([Date], "YYYY") & " T" & QUARTER([Date]),
				    "Semestre",      IF(MONTH([Date]) <= 6, "1o Sem", "2o Sem")
				)

	annotation PBI_ResultType = Table

	annotation __PBI_MarkAsDateTable = column="Date"

